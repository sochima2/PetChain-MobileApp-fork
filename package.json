{
  "name": "petchain-mobile",
  "version": "1.0.0",
  "description": "PetChain — Secure pet health records, medication reminders, QR scanning, and emergency SOS, all powered by blockchain verification.",
  "author": "PetChain, Inc. <support@petchain.app> (https://petchain.app)",
  "homepage": "https://petchain.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/DogStark/PetChain-MobileApp.git"
  },
  "license": "MIT",
  "keywords": [
    "pet",
    "health",
    "medical-records",
    "blockchain",
    "qr-scanner",
    "medication-reminders",
    "vet",
    "pet-care",
    "pet-tracker",
    "react-native",
    "expo",
    "stellar"
  ],
  "scripts": {
    "start": "APP_ENV=development expo start",
    "start:staging": "APP_ENV=staging expo start",
    "start:production": "APP_ENV=production expo start",
    "eas:build:dev": "eas build --platform all --profile development",
    "eas:build:preview": "eas build --platform all --profile preview",
    "eas:build:prod": "eas build --platform all --profile production",
    "test": "jest --runInBand",
    "test:ci": "jest --runInBand --ci --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "e2e:test": "maestro test .maestro/flows/smoke-test.yaml",
    "prepare": "husky",
    "migrate": "ts-node backend/src/db/migrate.ts",
    "seed": "ts-node backend/seeds/index.ts",
    "seed:dev": "ts-node backend/seeds/index.ts --owners 5 --vets 3 --pets 2 --records 3 --appointments 2 --medications 1",
    "seed:test": "ts-node backend/seeds/index.ts --owners 2 --vets 1 --pets 1 --records 1 --appointments 1 --medications 1",
    "seed:large": "ts-node backend/seeds/index.ts --owners 20 --vets 10 --pets 3 --records 5 --appointments 3 --medications 2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.[jt]sx?$": "babel-jest"
    },
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ],
    "moduleNameMapper": {
      "^react-native$": "<rootDir>/src/__mocks__/react-native.ts",
      "^react-native-keychain$": "<rootDir>/src/__mocks__/react-native-keychain.ts",
      "^react-native-image-picker$": "<rootDir>/src/__mocks__/react-native-image-picker.ts",
      "^react-native-image-resizer$": "<rootDir>/src/__mocks__/react-native-image-resizer.ts",
      "^@react-native-community/netinfo$": "<rootDir>/src/__mocks__/@react-native-community/netinfo.ts",
      "^expo-constants$": "<rootDir>/src/__mocks__/expo-constants.ts",
      "^expo-sqlite$": "<rootDir>/src/__mocks__/expo-sqlite.ts",
      "^expo-notifications$": "<rootDir>/src/__mocks__/expo-notifications.ts",
      "^expo-secure-store$": "<rootDir>/src/__mocks__/expo-secure-store.ts"
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "backend/**/*.ts",
      "!src/**/__tests__/**",
      "!src/**/__mocks__/**"
    ]
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-native-community/geolocation": "^3.4.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-navigation/bottom-tabs": "6.6.1",
    "@react-navigation/native": "6.1.18",
    "@react-navigation/native-stack": "6.11.0",
    "@sentry/react-native": "^6.5.0",
    "@stellar/freighter-api": "^6.0.1",
    "@stellar/stellar-sdk": "^15.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@urql/core": "^5.0.0",
    "axios": "^1.15.2",
    "crypto-js": "^4.2.0",
    "expo-barcode-scanner": "^13.0.1",
    "expo-image-manipulator": "^13.0.6",
    "expo-camera": "^55.0.16",
    "expo-constants": "^18.0.13",
    "expo-notifications": "^0.31.1",
    "expo-screen-capture": "^55.0.13",
    "expo-secure-store": "^14.0.1",
    "expo-splash-screen": "^55.0.19",
    "expo-sqlite": "^15.0.6",
    "expo-updates": "^0.26.0",
    "express": "^5.2.1",
    "graphql": "^16.0.0",
    "i18next": "^26.0.8",
    "jsonwebtoken": "^9.0.3",
    "react-i18next": "^17.0.6",
    "react-native-image-picker": "^7.0.0",
    "react-native-webrtc": "^124.0.3",
    "react-native-image-resizer": "^1.4.5",
    "react-native-keychain": "^10.0.0",
    "react-native-ssl-pinning": "^1.5.3",
    "helmet": "^8.0.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "9.26.0",
    "@storybook/addon-actions": "^8.6.0",
    "@storybook/addon-ondevice-actions": "^8.6.0",
    "@storybook/addon-ondevice-backgrounds": "^8.6.0",
    "@storybook/addon-ondevice-controls": "^8.6.0",
    "@storybook/addon-ondevice-notes": "^8.6.0",
    "@storybook/blocks": "^8.6.0",
    "@storybook/react-native": "^8.6.0",
    "@types/connect-redis": "^0.0.23",
    "@types/cors": "^2.8.19",
    "@types/helmet": "^0.0.48",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.1",
    "@types/react-native": "^0.72.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "axios-mock-adapter": "^2.1.0",
    "babel-plugin-react-native-web": "^0.19.13",
    "eslint": "9.26.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-prettier": "5.4.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "husky": "9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "15.5.1",
    "msw": "^2.13.6",
    "prettier": "3.5.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.59.0",
    "vitest": "^4.1.5"
  }
}
